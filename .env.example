# cloneX Environment Configuration
# Copy this file to .env and adjust values for your environment.

# Application
APP_NAME=cloneX
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-key-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=cloneforge
POSTGRES_PASSWORD=cloneforge_secret
POSTGRES_DB=cloneforge
DATABASE_URL=postgresql+asyncpg://cloneforge:cloneforge_secret@db:5432/cloneforge

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage/projects
# AWS S3 compatible (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=cloneforge-projects
# S3_ENDPOINT_URL=

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=60
MAX_CRAWL_DEPTH=5
MAX_CONCURRENT_REQUESTS=8
ALLOW_PRIVATE_NETWORKS=false

# Admin user seeded on first run
# Default login: admin@cloneforge.local / admin
FIRST_SUPERUSER_EMAIL=admin@cloneforge.local
FIRST_SUPERUSER_PASSWORD=admin
